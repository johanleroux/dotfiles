#!/usr/bin/env bash

set -e

echo -e "\e[32m\nUpdate system packages\e[0m"
yay -Syyu --noconfirm

orphans=$(yay -Qtdq || true)
if [[ -n $orphans ]]; then
  echo -e "\e[32m\nRemove orphan system packages\e[0m"
  for pkg in $orphans; do
    yay -Rs --noconfirm "$pkg" || true
  done
  echo
fi

yay -Scc --noconfirm
